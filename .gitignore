# ============================================================
# Django
# ============================================================

# Environment & secrets
.env
.env.*
!.env.example

# Database
db.sqlite3
db.sqlite3-journal
*.db

# Media & uploads (user-generated content — not for version control)
media/
!media/.gitkeep

# Static files (collected by collectstatic — generated, not source)
staticfiles/
static_root/

# Django migrations (optional — remove this block if you commit migrations)
# apps/*/migrations/*.py
# !apps/*/migrations/__init__.py

# Django cache framework
cache/
.cache/

# Django Q2 / task queue
django_q/

# Celery (future-proofing)
celerybeat-schedule
celerybeat.pid

# Local settings overrides
local_settings.py
config/settings/local.py

